# Env precedence: shell env (e.g. ~/.zprofile exports) > this .env file.
# If you already export these in your shell, you don't need to fill .env at all.
# This file is for reviewers / fresh machines that don't have the vars in shell.

# LiveKit Cloud credentials — sign up free at https://cloud.livekit.io
# Project Settings → Keys → "Create new key"
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI — used by the agent for Whisper STT, gpt-4o-mini grader, and tts-1
OPENAI_API_KEY=

# Optional: frontend API base URL when not using the dev proxy
# VITE_API_URL=http://localhost:8000

# Optional: cheat phrase that force-passes the current concept (default: abracadabra)
# VOICE_TUTOR_CHEAT=abracadabra
