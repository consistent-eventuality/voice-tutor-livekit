# LiveKit Cloud credentials — sign up free at https://cloud.livekit.io
# Project Settings → Keys → "Create new key"
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI — used by the agent worker for the Realtime voice model
OPENAI_API_KEY=

# Optional: override the OpenAI Realtime model the agent uses
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Optional: frontend API base URL when not using the dev proxy
# VITE_API_URL=http://localhost:8000
